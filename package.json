{
  "name": "d-o-gist-hub",
  "version": "0.1.0",
  "description": "d.o. Gist Hub — offline-first GitHub Gist management app with token-driven design and Android support",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:coverage": "playwright test --coverage",
    "test:browser": "playwright test tests/browser/",
    "test:mobile": "playwright test tests/mobile/",
    "test:offline": "playwright test tests/offline/",
    "test:android": "playwright test tests/android/",
    "test:visual": "playwright test --update-snapshots",
    "test:a11y": "playwright test tests/accessibility/",
    "test:report": "playwright show-report",
    "init:design": "node scripts/init-design-tokens.js",
    "generate:icons": "node scripts/generate-icons.mjs",
    "cap:sync": "npx cap sync android",
    "cap:android:open": "npx cap open android",
    "build:android": "npm run build && npm run cap:sync",
    "quality": "./scripts/quality_gate.sh"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "idb": "^8.0.3",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.45.0",
    "@types/node": "^25.6.0",
    "canvas": "^3.2.3",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.8.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.0",
    "vite": "^5.4.0"
  }
}
