{
  "name": "d-o-gist-hub",
  "version": "0.2.1",
  "description": "d.o. Gist Hub — offline-first GitHub Gist management app with token-driven design and Android support",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run tokens:build && tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "pnpm run tokens:build && tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:e2e:screenshots": "playwright test --project=screenshots",
    "test:e2e:visual": "playwright test --project=visual",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:coverage": "vitest run --coverage",
    "test:browser": "playwright test tests/browser/",
    "test:mobile": "playwright test tests/mobile/",
    "test:offline": "playwright test tests/offline/",
    "test:android": "playwright test tests/android/",
    "test:visual": "playwright test --project=visual",
    "test:a11y": "playwright test tests/accessibility/",
    "test:report": "playwright show-report",
    "test:unit": "pnpm run tokens:build && vitest run",
    "test:unit:watch": "pnpm run tokens:build && vitest",
    "generate:icons": "node scripts/generate-icons.mjs",
    "verify:responsive": "npx tsx scripts/verify-ui.ts",
    "cap:sync": "npx cap sync android",
    "cap:android:open": "npx cap open android",
    "build:android": "pnpm run build && pnpm run cap:sync",
    "analyze": "ANALYZE=true pnpm run build",
    "bundle-budget": "bash scripts/check-bundle-size.sh --skip-build",
    "commitlint:last": "commitlint --from=HEAD~1 --to=HEAD --verbose",
    "quality": "./scripts/quality_gate.sh",
    "tokens:build": "tsx sd.config.ts",
    "tokens:watch": "tsx sd.config.ts --watch",
    "changelog": "git-cliff --output CHANGELOG.md",
    "changelog:latest": "git-cliff --latest",
    "postinstall": "node scripts/install-commit-hook.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/anton": "^5.2.7",
    "idb": "^8.0.3",
    "shiki": "^4.3.0",
    "web-vitals": "^5.2.0"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "canvas": "^3.0.1",
    "commitlint": "^21.2.0",
    "esbuild": "^0.28.1",
    "fake-indexeddb": "^6.0.0",
    "html-escaper": "^3.0.3",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "rollup-plugin-visualizer": "^7.0.1",
    "style-dictionary": "^5.5.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.1",
    "vitest": "^4.1.6"
  }
}
