{
  "$schema": "node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "plan038_comment": "Implements plan 038 item D6 — mutation testing",
  "mutate": [
    "src/services/sync/**/*.ts",
    "src/services/security/**/*.ts"
  ],
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "concurrency": 4,
  "timeoutMS": 30000,
  "thresholds": {
    "break": 70
  },
  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "cleanTempDir": "always",
  "ignorePatterns": [
    ".claude/",
    ".gemini/",
    ".qwen/",
    ".cursor/",
    ".agents/skills/skills",
    "android/",
    "plans/archive/",
    "reports/",
    ".stryker-tmp/"
  ]
}
