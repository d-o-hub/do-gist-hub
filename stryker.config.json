{
  "$schema": "node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "mutate": [
    "src/services/sync/**/*.ts",
    "src/services/security/**/*.ts",
    "src/services/github/device-flow.ts",
    "src/routes/settings.ts",
    "src/components/gist-card.ts",
    "src/components/gist-detail.ts"
  ],
  "plugins": [
    "@stryker-mutator/vitest-runner",
    "@stryker-mutator/typescript-checker"
  ],
  "testRunner": "vitest",
  "checkers": ["typescript"],
  "typescriptChecker": {
    "prioritizePerformanceOverAccuracy": false
  },
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "concurrency": 4,
  "timeoutMS": 30000,
  "thresholds": {
    "break": 70
  },
  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "clearTextReporter": {
    "allowColor": true
  },
  "ignorePatterns": [".claude", ".cursor", ".agents", ".qwen", ".gemini", ".jules"],
  "tempDirName": ".stryker-tmp",
  "cleanTempDir": true
}
