{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Swarm Handoff Schema",
  "description": "Structured handoff contract for multi-agent swarm coordination. Ensures consistent data passing between agents.",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version for forward compatibility",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of handoff"
    },
    "sourceAgent": {
      "type": "string",
      "description": "Name or role of the agent producing this handoff"
    },
    "targetAgent": {
      "type": "string",
      "description": "Name or role of the agent consuming this handoff"
    },
    "context": {
      "type": "object",
      "description": "Shared context passed between agents",
      "minProperties": 1,
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "description": "Files, data, or references produced during the task",
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "File path relative to repo root" },
          "type": {
            "type": "string",
            "enum": ["created", "modified", "deleted", "reference"]
          },
          "summary": { "type": "string", "description": "Brief description of the artifact" }
        },
        "required": ["path", "type"]
      }
    },
    "decisions": {
      "type": "array",
      "description": "Key decisions made that the next agent should know about",
      "items": {
        "type": "object",
        "properties": {
          "topic": { "type": "string" },
          "decision": { "type": "string" },
          "rationale": { "type": "string" }
        },
        "required": ["topic", "decision"]
      }
    },
    "nextSteps": {
      "type": "array",
      "description": "Suggested follow-up tasks for the receiving agent",
      "items": { "type": "string" }
    }
  },
  "required": ["version", "timestamp", "sourceAgent", "targetAgent", "context"]
}
