{
  "ci": {
    "collect": {
      "staticDistDir": "dist",
      "numberOfRuns": 1,
      "settings": {
        "onlyCategories": [
          "performance",
          "accessibility"
        ]
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.5
          }
        ],
        "categories:accessibility": [
          "warn",
          {
            "minScore": 0.7
          }
        ],
        "largest-contentful-paint": [
          "warn",
          {
            "maxNumericValue": 4000
          }
        ],
        "interaction-to-next-paint": [
          "warn",
          {
            "maxNumericValue": 500
          }
        ],
        "cumulative-layout-shift": [
          "warn",
          {
            "maxNumericValue": 0.25
          }
        ],
        "canonical": "off",
        "crawlable-anchors": "off",
        "csp-xss": "off",
        "charset": "off",
        "deprecations": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
