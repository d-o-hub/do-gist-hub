{
  "ci": {
    "collect": {
      "staticDistDir": "dist",
      "numberOfRuns": 1,
      "settings": {
        "onlyCategories": [
          "performance",
          "accessibility"
        ]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.6
          }
        ],
        "categories:accessibility": [
          "warn",
          {
            "minScore": 0.8
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
